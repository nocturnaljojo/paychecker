# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.local.example is committed as a template.

# --- Clerk (Phase 0) ---
# Publishable key from clerk.com → Application → API Keys.
# Vite's VITE_* prefix exposes this var to client JS at build time;
# only put values that are SAFE to be public-readable here.
# (Clerk publishable keys ARE designed to be public.)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# --- Supabase (Phase 0) ---
# Project URL + anon (publishable) key from supabase.com →
# Project Settings → API. Anon key is RLS-scoped and safe in client JS.
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_or_sb_publishable_PLACEHOLDER

# =====================================================================
# SERVER-SIDE ONLY — never VITE_ prefix any of the below
# =====================================================================
# These vars are used by api/* Vercel serverless functions (Sprint B2+).
# They MUST NOT be VITE_-prefixed: Vite bundles every VITE_* var into
# client JS at build time, which would leak secrets to every browser
# that loads the app. Vercel project env (Settings → Environment
# Variables) is the production home; .env.local works for local dev.
#
# A common failure mode: copy a third-party doc that names the var
# `VITE_ANTHROPIC_API_KEY` or similar. DO NOT. The non-VITE_ prefix
# is what keeps the key out of the client bundle.

# --- Anthropic API (Sprint B2 — server-side classification + extraction) ---
# Get from console.anthropic.com → Settings → API Keys.
# Used in api/classify.ts (Haiku 4.5 vision classification).
# Cost guardrail: 50 docs/worker/day cap, ~$0.005/classify call.
# Privacy: per ADR-013 + R-010, document content goes to Anthropic API
# only during the API session; not retained, not used for training.
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER

# --- Clerk secret key (Sprint B2 — server-side JWT verification) ---
# Get from clerk.com → Application → API Keys → Secret keys.
# Used in api/classify.ts via @clerk/backend `verifyToken()` to verify
# the Authorization Bearer JWT forwarded from the client.
CLERK_SECRET_KEY=sk_test_PLACEHOLDER

# --- Supabase service-role key (Sprint B2 — server-side DB writes) ---
# Get from supabase.com → Project Settings → API → service_role key.
# Used in api/classify.ts for INSERT into document_classifications
# (operator-only RLS) and storage.move() (no DELETE policy on objects).
# WARNING: service-role bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ_or_sb_secret_PLACEHOLDER

# --- DO NOT add the following ---
# Clerk publishable keys with sk_ prefix — that's a SECRET key in disguise.
# Anything starting with `sk_*` belongs above (server-side), not in any
# VITE_*-prefixed line. The src/config/clerk.ts loader actively rejects
# sk_* values in VITE_CLERK_PUBLISHABLE_KEY (see SEC-001 lesson).
# Supabase service-role keys (sb_secret_*, anything containing
#   '"role":"service_role"') — they bypass RLS. Server-side only (above).
