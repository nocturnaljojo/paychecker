# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.local.example is committed as a template.

# --- Clerk (Phase 0) ---
# Publishable key from clerk.com → Application → API Keys.
# Vite's VITE_* prefix exposes this var to client JS at build time;
# only put values that are SAFE to be public-readable here.
# (Clerk publishable keys ARE designed to be public.)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# --- Supabase (Phase 0) ---
# Project URL + anon (publishable) key from supabase.com →
# Project Settings → API. Anon key is RLS-scoped and safe in client JS.
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_or_sb_publishable_PLACEHOLDER

# --- DO NOT add the following to this file ---
# Clerk secret keys (sk_test_*, sk_live_*) — server-side only.
#   Phase 0 has no backend, so the secret has no home in this project yet.
#   Phase 1+ keeps it in Fly.io / Vercel project env (server-side, never VITE_*).
# Supabase service-role keys (sb_secret_*, anything containing
#   '"role":"service_role"') — they bypass RLS. Server-side only.
