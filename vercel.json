{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api|design-system|assets|@vite|@react-refresh|src|node_modules|favicon\\.ico|robots\\.txt|.*\\.(?:tsx|ts|jsx|js|mjs|css|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot|map)).*)",
      "destination": "/"
    }
  ]
}